# -----------------------------------------------------------------------------
# CONFIGURAÇÃO DE AMBIENTE - BUJO FOCUS
# Copie este arquivo para .env e preencha as credenciais abaixo
# -----------------------------------------------------------------------------

# URL do seu projeto Supabase (encontre em Project Settings > API > Project URL)
VITE_SUPABASE_URL=https://seu-projeto-supabase.supabase.co

# Chave pública anônima do Supabase (encontre em Project Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public-do-supabase
