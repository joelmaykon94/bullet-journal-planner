#!/bin/bash
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not a git repository."
  exit 1
fi

REF="${1:-HEAD}"

# Get list of changed files, filtering out build and dependency folders
FILES=$(git diff --name-only "$REF" 2>/dev/null | grep -vE '(node_modules|dist|\.angular|\.git)')

# Fallback to status porcelain to capture untracked files when comparing to HEAD
if [ -z "$FILES" ] && [ "$REF" = "HEAD" ]; then
  FILES=$(git status --porcelain | awk '{print $2}' | grep -vE '(node_modules|dist|\.angular|\.git)')
fi

if [ -z "$FILES" ]; then
  echo "No changed files found."
  echo "Total changed files: 0"
  exit 0
fi

echo "$FILES"
COUNT=$(echo "$FILES" | wc -l)
echo "----------------------------------------"
echo "Total changed files: $COUNT"
